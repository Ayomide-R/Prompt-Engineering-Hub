@inherits LayoutComponentBase

<MudThemeProvider @ref="@_mudThemeProvider" @bind-IsDarkMode="@_isDarkMode" Theme="_theme" />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Class="mud-appbar-glass px-4">
        <MudIconButton Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Primary" Size="Size.Large" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-2 gradient-text" Style="font-weight: 800; letter-spacing: -0.5px;">PromptHub</MudText>
        <MudSpacer />
        <div class="d-flex align-center gap-4">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)" Color="Color.Inherit" OnClick="@((e) => DarkModeToggle())" />
            <AuthorizeView>
                <Authorized>
                    <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <MudMenuItem OnClick="Logout">Logout</MudMenuItem>
                    </MudMenu>
                </Authorized>
                <NotAuthorized>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="px-6 glow-btn" href="login">Login</MudButton>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </MudAppBar>
    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0" Class="mud-drawer-premium">
        <NavMenu />
    </MudDrawer>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-8 pt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
    private MudThemeProvider? _mudThemeProvider;

    private MudTheme _theme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#8B5CF6",
            Secondary = "#ec4899",
            AppbarBackground = "#ffffffcc",
            AppbarText = "#1e1e1e",
            Background = "#f8fafc",
            Surface = "#ffffff",
            DrawerBackground = "#ffffff",
            DrawerText = "#475569",
            TextPrimary = "#1e1e1e",
            ActionDefault = "#8B5CF6"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#8B5CF6",
            Secondary = "#ec4899",
            AppbarBackground = "#121214cc",
            AppbarText = "#f8fafc",
            Background = "#0a0a0c",
            Surface = "#121214",
            DrawerBackground = "#121214",
            DrawerText = "#94a3b8",
            TextPrimary = "#f8fafc",
            ActionDefault = "#8B5CF6"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "16px",
            AppBarHeight = "72px"
        },
        Typography = new Typography()
        {
            Default = new Default() { FontFamily = new[] { "Inter", "Helvetica", "Arial", "sans-serif" } },
            H1 = new H1() { FontFamily = new[] { "Outfit", "sans-serif" }, FontWeight = 800, LetterSpacing = "-0.02em" },
            H2 = new H2() { FontFamily = new[] { "Outfit", "sans-serif" }, FontWeight = 700, LetterSpacing = "-0.02em" },
            H3 = new H3() { FontFamily = new[] { "Outfit", "sans-serif" }, FontWeight = 700, LetterSpacing = "-0.01em" },
            H4 = new H4() { FontFamily = new[] { "Outfit", "sans-serif" }, FontWeight = 700, LetterSpacing = "-0.01em" },
            H5 = new H5() { FontFamily = new[] { "Outfit", "sans-serif" }, FontWeight = 600 },
            H6 = new H6() { FontFamily = new[] { "Outfit", "sans-serif" }, FontWeight = 600 }
        }
    };

    void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    void DarkModeToggle()
    {
        _isDarkMode = !_isDarkMode;
    }

    [Inject] private AuthService AuthService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }
}

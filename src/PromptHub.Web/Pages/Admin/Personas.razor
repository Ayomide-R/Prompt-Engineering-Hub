@page "/admin/personas"
@attribute [Authorize(Roles = "Admin")]
@inject HttpClient Http
@inject ISnackbar Snackbar
@using PromptHub.Web.Models

<PageTitle>PromptHub - Global Personas</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Admin: Global Personas</MudText>
<MudText Class="mb-8">Manage the master instructions for system-wide roles.</MudText>

@if (_personas == null)
{
    <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="my-7" />
}
else
{
    <MudGrid>
        @foreach (var role in Enum.GetValues<RoleType>())
        {
            var persona = _personas.FirstOrDefault(p => p.Role == role) ?? new GlobalPersonaDto { Role = role };
            <MudItem xs="12" md="6">
                <MudCard Elevation="2" Class="mb-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@role</MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudIconButton Icon="@Icons.Material.Filled.Save" Color="Color.Primary" OnClick="@(() => SavePersona(persona))" />
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudTextField @bind-Value="persona.Description" Label="Description (Internal)" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4" />
                        <MudTextField @bind-Value="persona.MasterInstruction" Label="Master Instruction" Variant="Variant.Outlined" Lines="5" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<GlobalPersonaDto>? _personas;

    protected override async Task OnInitializedAsync()
    {
        await LoadPersonas();
    }

    private async Task LoadPersonas()
    {
        try
        {
            _personas = await Http.GetFromJsonAsync<List<GlobalPersonaDto>>("api/persona");
        }
        catch (Exception)
        {
            _personas = new();
        }
    }

    private async Task SavePersona(GlobalPersonaDto persona)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/persona", persona);
            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add($"Saved persona for {persona.Role}", Severity.Success);
                await LoadPersonas();
            }
            else
            {
                Snackbar.Add("Failed to save persona.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }
}

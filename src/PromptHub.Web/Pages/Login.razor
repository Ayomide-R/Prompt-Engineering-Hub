@page "/login"
@layout MainLayout
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>PromptHub - Login</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="mt-16 pt-16">
    <MudPaper Elevation="0" Class="premium-card pa-10 glass-panel">
        <div class="text-center mb-8">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Primary" Style="font-size: 3rem;" />
            <MudText Typo="Typo.h4" Class="mt-4 gradient-text" Style="font-weight: 800;">Welcome Back</MudText>
            <MudText Typo="Typo.body2" Class="text-muted mt-2">Sign in to continue your creative journey.</MudText>
        </div>

        <MudForm @ref="_form" @bind-IsValid="@_success">
            <MudTextField T="string" Label="Email" Required="true" 
                          RequiredError="Email address is required"
                          @bind-Value="_model.Email" FullWidth="true" 
                          Variant="Variant.Outlined" Class="mb-6 modern-textfield" 
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" 
                          AdornmentColor="Color.Primary" />

            <MudTextField T="string" Label="Password" Required="true" 
                          RequiredError="Password is required"
                          @bind-Value="_model.Password" InputType="InputType.Password" 
                          FullWidth="true" Variant="Variant.Outlined" Class="mb-8 modern-textfield"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" 
                          AdornmentColor="Color.Primary" />
            
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" 
                       Size="Size.Large" OnClick="Submit" Disabled="@_processing" 
                       Class="py-3 glow-btn" Style="font-weight: 700; border-radius: 12px;">
                @if (_processing)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Authenticating...</MudText>
                }
                else
                {
                    <MudText>Sign In</MudText>
                }
            </MudButton>
            
            <div class="text-center mt-8">
                <MudText Typo="Typo.body2" Class="text-muted">
                    New to PromptHub? <MudLink href="register" Underline="Underline.Hover" Color="Color.Primary" Style="font-weight: 600;">Create an account</MudLink>
                </MudText>
            </div>
        </MudForm>
    </MudPaper>
</MudContainer>

<style>
    .modern-textfield .mud-input-outlined-border { border-color: var(--border-subtle) !important; }
    .modern-textfield:hover .mud-input-outlined-border { border-color: var(--primary) !important; }
</style>

@code {
    private MudForm? _form;
    private bool _success;
    private bool _processing;
    private LoginRequest _model = new();

    private async Task Submit()
    {
        await _form!.Validate();
        if (!_success) return;

        _processing = true;
        try 
        {
            var result = await AuthService.LoginAsync(_model);
            if (result)
            {
                Snackbar.Add("Welcome back!", Severity.Success);
                Navigation.NavigateTo("");
            }
            else
            {
                Snackbar.Add("Invalid credentials. Please try again.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Connection error: {ex.Message}", Severity.Error);
        }
        finally 
        {
            _processing = false;
        }
    }
}
